# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags API — variáveis de ambiente
# Copie para .env e ajuste os valores. Nunca commite o .env real.
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/feature_flags

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — OBRIGATÓRIO em produção (mínimo 32 bytes)
# Gere com: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_THIS_IS_NOT_SECURE

# Ambiente: development | staging | production
# Em production a app recusa subir sem SECRET_KEY segura.
ENVIRONMENT=development

# Modo debug (false em produção)
DEBUG=false

# Hosts permitidos pelo TrustedHostMiddleware (separados por vírgula)
# Em produção: ALLOWED_HOSTS=api.meudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens permitidas pelo CORS (separadas por vírgula)
# Em produção: CORS_ORIGINS=https://app.meudominio.com
CORS_ORIGINS=

# Pool de conexões SQLAlchemy
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Sentry — error tracking e tracing distribuído
# Obtenha o DSN em https://sentry.io → Project Settings → Client Keys
# Deixe vazio para desativar.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
